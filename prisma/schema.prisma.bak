// ============================================================
//  UTEHY - Mạng Xã Hội Quản Lý Sự Kiện Ngoại Khóa
//  File: prisma/schema.prisma
//  Database: MySQL 8.0+
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================
//  ENUMS
// ============================================================

enum Role {
  STUDENT
  PAGE_ADMIN
  SYSTEM_ADMIN
}

enum EventStatus {
  PENDING
  APPROVED
  REJECTED
  ONGOING
  CLOSED
}

enum RegistrationStatus {
  REGISTERED
  APPROVED
  ATTENDED
  ABSENT
  CANCELLED
}

enum CheckinMethod {
  QR_SCAN
  MANUAL
}

enum NotificationType {
  EVENT_APPROVED
  EVENT_NEW
  EVENT_REMINDER
  CHECKIN_SUCCESS
  REGISTRATION_OPEN
  SYSTEM
}

// ============================================================
//  MODULE: auth/ + users/
// ============================================================

model User {
  id         String   @id @default(uuid()) @db.VarChar(36)
  email      String   @unique @db.VarChar(255)
  password   String   @db.VarChar(255)
  role       Role     @default(STUDENT)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  profile        Profile?
  refresh_tokens RefreshToken[]
  managed_pages  PageMember[]
  registrations  Registration[]
  checkins       Checkin[]
  likes          Like[]
  comments       Comment[]
  notifications  Notification[]
  posts          Post[]

  @@map("users")
}

model Profile {
  id              String   @id @default(uuid()) @db.VarChar(36)
  user_id         String   @unique @db.VarChar(36)
  student_id      String?  @unique @db.VarChar(20)
  full_name       String   @db.VarChar(150)
  class_name      String?  @db.VarChar(50)
  faculty         String?  @db.VarChar(150)
  phone           String?  @db.VarChar(15)
  avatar_url      String?  @db.Text
  training_points Int      @default(0)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  user        User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_badges UserBadge[]

  @@map("profiles")
}

model RefreshToken {
  id         String   @id @default(uuid()) @db.VarChar(36)
  user_id    String   @db.VarChar(36)
  token      String   @unique @db.VarChar(512)
  expires_at DateTime
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("refresh_tokens")
}

// ============================================================
//  MODULE: pages/
// ============================================================

model Page {
  id          String   @id @default(uuid()) @db.VarChar(36)
  name        String   @db.VarChar(255)
  slug        String   @unique @db.VarChar(100)
  description String?  @db.Text
  avatar_url  String?  @db.Text
  cover_url   String?  @db.Text
  is_verified Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  members   PageMember[]
  posts     Post[]
  events    Event[]
  followers PageFollower[]

  @@map("pages")
}

model PageMember {
  id        String   @id @default(uuid()) @db.VarChar(36)
  page_id   String   @db.VarChar(36)
  user_id   String   @db.VarChar(36)
  is_owner  Boolean  @default(false)
  joined_at DateTime @default(now())

  page Page @relation(fields: [page_id], references: [id], onDelete: Cascade)
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([page_id, user_id])
  @@index([user_id]) 
  @@map("page_members")
}

model PageFollower {
  id          String   @id @default(uuid()) @db.VarChar(36)
  page_id     String   @db.VarChar(36)
  user_id     String   @db.VarChar(36)
  followed_at DateTime @default(now())

  page Page @relation(fields: [page_id], references: [id], onDelete: Cascade)

  @@unique([page_id, user_id])
  @@index([user_id])
  @@map("page_followers")
}

// ============================================================
//  MODULE: events/
// ============================================================

model EventCategory {
  id                      Int     @id @default(autoincrement())
  name                    String  @unique @db.VarChar(100)
  default_training_points Int     @default(0)
  color_hex               String? @db.VarChar(7)

  events Event[]

  @@map("event_categories")
}

model Event {
  id                    String      @id @default(uuid()) @db.VarChar(36)
  page_id               String      @db.VarChar(36)
  category_id           Int?
  title                 String      @db.VarChar(255)
  description           String?     @db.LongText
  banner_url            String?     @db.Text
  location              String?     @db.VarChar(500)
  latitude              Decimal?    @db.Decimal(10, 8)
  longitude             Decimal?    @db.Decimal(11, 8)
  checkin_radius_m      Int         @default(200)
  start_time            DateTime
  end_time              DateTime
  registration_deadline DateTime
  max_slots             Int?
  current_slots         Int         @default(0)
  training_points       Int         @default(0)
  requires_approval     Boolean     @default(false)
  status                EventStatus @default(PENDING)
  rejection_reason      String?     @db.Text
  created_at            DateTime    @default(now())
  updated_at            DateTime    @updatedAt

  page         Page           @relation(fields: [page_id], references: [id], onDelete: Cascade)
  category     EventCategory? @relation(fields: [category_id], references: [id], onDelete: SetNull)
  registrations Registration[]
  qr_tokens    QrToken[]
  posts        Post[]

  @@index([status, start_time])
  @@index([page_id, status])
  @@index([registration_deadline])
  @@map("events")
}

// ============================================================
//  MODULE: registrations/
// ============================================================

model Registration {
  id            String             @id @default(uuid()) @db.VarChar(36)
  user_id       String             @db.VarChar(36)
  event_id      String             @db.VarChar(36)
  status        RegistrationStatus @default(REGISTERED)
  registered_at DateTime           @default(now())
  updated_at    DateTime           @updatedAt

  user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  event   Event   @relation(fields: [event_id], references: [id], onDelete: Cascade)
  checkin Checkin?

  @@unique([user_id, event_id])
  @@index([event_id, status])
  @@index([user_id, status])
  @@map("registrations")
}

// ============================================================
//  MODULE: checkin/
// ============================================================

model QrToken {
  id         String   @id @default(uuid()) @db.VarChar(36)
  event_id   String   @db.VarChar(36)
  token      String   @unique @db.VarChar(255) 
  expires_at DateTime
  created_at DateTime @default(now())

  event    Event     @relation(fields: [event_id], references: [id], onDelete: Cascade)
  checkins Checkin[]

  @@index([token, expires_at])
  @@index([event_id])
  @@map("qr_tokens")
}

model Checkin {
  id              String        @id @default(uuid()) @db.VarChar(36)
  registration_id String        @unique @db.VarChar(36)
  user_id         String        @db.VarChar(36)
  qr_token_id     String?       @db.VarChar(36)
  method          CheckinMethod @default(QR_SCAN)
  checkin_lat     Decimal?      @db.Decimal(10, 8)
  checkin_lng     Decimal?      @db.Decimal(11, 8)
  points_awarded  Int           @default(0)
  checked_in_at   DateTime      @default(now())

  registration Registration @relation(fields: [registration_id], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  qr_token     QrToken?     @relation(fields: [qr_token_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@map("checkins")
}

// ============================================================
//  MODULE: posts/ + comments/
// ============================================================

model Post {
  id             String   @id @default(uuid()) @db.VarChar(36)
  page_id        String   @db.VarChar(36)
  author_id      String   @db.VarChar(36)
  event_id       String?  @db.VarChar(36)
  content        String   @db.LongText 
  image_urls     Json?    
  likes_count    Int      @default(0)
  comments_count Int      @default(0)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  page     Page      @relation(fields: [page_id], references: [id], onDelete: Cascade)
  author   User      @relation(fields: [author_id], references: [id], onDelete: Cascade)
  event    Event?    @relation(fields: [event_id], references: [id], onDelete: SetNull)
  likes    Like[]
  comments Comment[]

  @@index([page_id, created_at(sort: Desc)])
  @@map("posts")
}

model Like {
  id         String   @id @default(uuid()) @db.VarChar(36)
  user_id    String   @db.VarChar(36)
  post_id    String   @db.VarChar(36)
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  post Post @relation(fields: [post_id], references: [id], onDelete: Cascade)

  @@unique([user_id, post_id])
  @@map("likes")
}

model Comment {
  id         String   @id @default(uuid()) @db.VarChar(36)
  user_id    String   @db.VarChar(36)
  post_id    String   @db.VarChar(36)
  parent_id  String?  @db.VarChar(36)
  content    String   @db.Text
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user    User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  post    Post      @relation(fields: [post_id], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentReplies", fields: [parent_id], references: [id], onDelete: Cascade)
  replies Comment[] @relation("CommentReplies")

  @@index([post_id, created_at])
  @@index([parent_id])
  @@map("comments")
}

// ============================================================
//  MODULE: notifications/
// ============================================================

model Notification {
  id         String           @id @default(uuid()) @db.VarChar(36)
  user_id    String           @db.VarChar(36)
  type       NotificationType
  title      String           @db.VarChar(255)
  body       String           @db.Text
  data       Json?            
  is_read    Boolean          @default(false)
  created_at DateTime         @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, is_read, created_at(sort: Desc)])
  @@map("notifications")
}

// ============================================================
//  MODULE: admin/ + gamification
// ============================================================

model Badge {
  id          Int    @id @default(autoincrement())
  name        String @unique @db.VarChar(100)
  description String @db.Text
  icon_url    String @db.Text
  condition   String @db.Text

  user_badges UserBadge[]

  @@map("badges")
}

model UserBadge {
  id         String   @id @default(uuid()) @db.VarChar(36)
  profile_id String   @db.VarChar(36)
  badge_id   Int
  awarded_at DateTime @default(now())

  profile Profile @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  badge   Badge   @relation(fields: [badge_id], references: [id], onDelete: Cascade)

  @@unique([profile_id, badge_id])
  @@map("user_badges")
}