# Server Configuration
PORT=3001
NODE_ENV=production

# Database (MySQL - provided by Render or other service)
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DATABASE"

# JWT Secrets (generate strong secrets for production)
JWT_ACCESS_SECRET=your_access_secret_key_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_key_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Redis (for session/socket management - provided by Render)
REDIS_HOST=your-redis-host.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password  # if applicable

# SMTP (for email notifications - optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Frontend URL (for CORS - comma-separated if multiple)
FRONTEND_URL=https://your-app.vercel.app

# Webhook secret (for Google Form integration - optional)
GOOGLE_FORM_WEBHOOK_SECRET=your-webhook-secret

# ngrok (for local tunneling - optional)
NGROK_AUTH_TOKEN=your-ngrok-token
node_modules/
dist/
.env
*.log